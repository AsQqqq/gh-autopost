# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token (classic) with repo:read scope
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list: owner/repo-name
REPOS=myorg/frontend,myorg/backend

# Branches to monitor (comma-separated)
BRANCHES=main

# ── Telegram ──────────────────────────────────────────────────────────────────
# Token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Supergroup / channel ID (usually negative, e.g. -1001234567890)
TELEGRAM_CHANNEL_ID=-1001234567890

# Topic (thread) ID inside the channel for news posts (0 = no topic)
TELEGRAM_TOPIC_ID=123

# Comma-separated Telegram user IDs to notify after each publish
ADMIN_IDS=111111111,222222222

# ── Behaviour ─────────────────────────────────────────────────────────────────
# Poll interval in seconds (keep low for near-realtime detection)
POLL_INTERVAL=30

# Number of new commits that trigger batched message instead of individual posts
BATCH_THRESHOLD=3

# Skip merge commits (true/false)
FILTER_MERGE_COMMITS=true

# Max commits to fetch per repo/branch per run
MAX_COMMITS_PER_RUN=100

# ── Message ───────────────────────────────────────────────────────────────────
# Signature appended to every published message
SIGNATURE=🤖 GH AutoPost

# ── Storage ───────────────────────────────────────────────────────────────────
# Path inside the container (mapped to ./data via docker-compose volume)
DB_PATH=/data/commits.db
