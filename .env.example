# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token (classic), scope: repo (read-only is enough)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Repositories to monitor, comma-separated: owner/repo
REPOS=myorg/frontend,myorg/backend

# Branches to monitor, comma-separated
BRANCHES=main

# ── Telegram ──────────────────────────────────────────────────────────────────
# Token from @BotFather — add the bot to your channel as admin
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Supergroup / channel ID (negative number, e.g. -1001234567890)
TELEGRAM_CHANNEL_ID=-1001234567890

# Topic (thread) ID inside the channel (0 = no topic / general)
TELEGRAM_TOPIC_ID=0

# Telegram user IDs to notify after each publish, comma-separated
ADMIN_IDS=111111111

# ── Behaviour ─────────────────────────────────────────────────────────────────
# Poll interval in seconds
POLL_INTERVAL=30

# Number of new commits that triggers a batched message instead of individual posts
BATCH_THRESHOLD=3

# Skip merge commits (true/false)
FILTER_MERGE_COMMITS=true

# Max commits to fetch per repo/branch per run
MAX_COMMITS_PER_RUN=100

# ── Message ───────────────────────────────────────────────────────────────────
# Signature appended to every published message
SIGNATURE=🤖 GH AutoPost

# ── Storage ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@hostname:5432/gh_autopost
